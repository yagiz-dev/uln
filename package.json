{
  "name": "universal-license-notice",
  "version": "0.1.1",
  "description": "Universal License Notice (uln) generates third-party license notices from package manager metadata.",
  "type": "module",
  "bin": {
    "uln": "dist/index.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx src/cli/index.ts",
    "build": "node scripts/build.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "keywords": [
    "license",
    "notice",
    "npm",
    "compliance",
    "cli"
  ],
  "homepage": "https://yagiz.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yagiz-dev/universal-license-notice.git"
  },
  "bugs": {
    "url": "https://github.com/yagiz-dev/universal-license-notice/issues"
  },
  "license": "MIT",
  "dependencies": {
    "commander": "^13.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@typescript-eslint/eslint-plugin": "^8.26.1",
    "@typescript-eslint/parser": "^8.26.1",
    "eslint": "^9.22.0",
    "globals": "^16.4.0",
    "prettier": "^3.5.3",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript-eslint": "^8.26.1",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
